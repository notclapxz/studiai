{
  // Cloudflare Worker que proxea Gemini para StudiAI. Deploy: ver README.md.
  // Corre en el plan FREE: el límite de 10ms de CPU NO lo afecta porque esperar
  // en fetch/streaming no cuenta como CPU (verificado en docs CF), el body grande
  // se reenvía sin parsear, y verificar el JWT (ES256/WebCrypto) es sub-ms.
  // Free da 100k req/día — de sobra para la beta. Pasar a Paid solo si se supera.
  "$schema": "https://developers.cloudflare.com/workers/configuration/wrangler.jsonc/",
  "name": "gemini-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",

  "observability": {
    "enabled": true
  },

  // Variable pública (NO secreto). Reemplaza <ref> por el de tu proyecto.
  "vars": {
    "SUPABASE_URL": "https://szysukwkumphvltaiwpn.supabase.co"
  },

  // Cache de entitlement por usuario. Crea el namespace y pega el id (ver README):
  //   wrangler kv namespace create ENTITLEMENT
  "kv_namespaces": [
    {
      "binding": "ENTITLEMENT",
      "id": "REEMPLAZAR_CON_KV_NAMESPACE_ID"
    }
  ],

  // Rate limiting por usuario — OPCIONAL, requiere Workers Paid. El código lo usa
  // solo si el binding existe (env.RL); en Free se omite y el gate de licencia
  // activa es el control contra abuso. Para activarlo (al pasar a Paid), descomenta:
  // "ratelimits": [
  //   { "name": "RL", "namespace_id": "1001", "simple": { "limit": 100, "period": 60 } }
  // ]

  // Secrets (NO van aquí; se setean con `wrangler secret put`):
  //   GEMINI_API_KEY, SUPABASE_ANON_KEY
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "studyai",
  "version": "0.7.0",
  "identifier": "com.sebastian.studyai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "studyai",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost https://*.supabase.co https://generativelanguage.googleapis.com https://checkout.culqi.com https://api.culqi.com https://github.com https://objects.githubusercontent.com",
        "script-src": "'self' 'unsafe-inline' https://checkout.culqi.com",
        "img-src": "'self' data: asset: http://asset.localhost blob: https://*.googleusercontent.com",
        "style-src": "'self' 'unsafe-inline'",
        "frame-src": "https://checkout.culqi.com"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["studiai"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/notclapxz/studiai/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxQjAzQ0NBRTAzQjQwMjQKUldRa1FEdmd5anl3OFJ4Y1QyOHFnSUxvcDRQM1hENGgrWHlaQ1M0V1NLUmQvUkdReUllMEpsbi8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
